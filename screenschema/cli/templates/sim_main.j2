// Generated by screenschema sim — do not edit manually
// Desktop simulator for {{ board_id }} ({{ display_width }}×{{ display_height }})

#include <cstdio>
#include <cstdlib>
#include <unistd.h>
#include "SDL.h"
#include "lvgl.h"

#include "ss_context.hpp"
#include "ss_widget_factory.hpp"
#include "ss_app_base.hpp"

{% for app in apps %}
#include "{{ app.class_name }}.hpp"
{% endfor %}
{% for app in apps %}
{% if app.icon_var %}
extern const lv_img_dsc_t {{ app.icon_var }};
{% endif %}
{% endfor %}

#include "handlers.hpp"

// Display dimensions from board profile
static constexpr int DISP_W = {{ display_width }};
static constexpr int DISP_H = {{ display_height }};
static constexpr int NUM_APPS = {{ apps | length }};

// SDL display + flush callback
static SDL_Window*   sdl_window   = nullptr;
static SDL_Renderer* sdl_renderer = nullptr;
static SDL_Texture*  sdl_texture  = nullptr;

static void sdl_flush_cb(lv_disp_drv_t* drv, const lv_area_t* area, lv_color_t* color_p) {
    int w = area->x2 - area->x1 + 1;
    int h = area->y2 - area->y1 + 1;

    SDL_Rect rect = { area->x1, area->y1, w, h };
    SDL_UpdateTexture(sdl_texture, &rect, color_p, w * sizeof(lv_color_t));
    SDL_RenderCopy(sdl_renderer, sdl_texture, nullptr, nullptr);
    SDL_RenderPresent(sdl_renderer);
    lv_disp_flush_ready(drv);
}

// SDL mouse → LVGL input device
static int32_t mouse_x = 0, mouse_y = 0;
static bool mouse_pressed = false;

static void sdl_mouse_read_cb(lv_indev_drv_t* drv, lv_indev_data_t* data) {
    data->point.x = mouse_x;
    data->point.y = mouse_y;
    data->state = mouse_pressed ? LV_INDEV_STATE_PRESSED : LV_INDEV_STATE_RELEASED;
}

// ---------------------------------------------------------------------------
// App instances
// ---------------------------------------------------------------------------
{% for app in apps %}
static {{ app.class_name }} app_{{ loop.index0 }};
{% endfor %}

struct AppEntry {
    const char*    name;
    SSAppBase*     app;
    const lv_img_dsc_t* icon;
};

static AppEntry app_table[NUM_APPS] = {
{% for app in apps %}
    { "{{ app.name }}", &app_{{ loop.index0 }}, {{ '&' + app.icon_var if app.icon_var else 'nullptr' }} },
{% endfor %}
};

// ---------------------------------------------------------------------------
// Launcher & app navigation
// ---------------------------------------------------------------------------
static bool want_back = false;

static void show_launcher();
static void show_app(int index);

static void launcher_btn_cb(lv_event_t* e) {
    int idx = (int)(intptr_t)lv_event_get_user_data(e);
    show_app(idx);
}

static void back_btn_cb(lv_event_t* e) {
    (void)e;
    want_back = true;
}

static void show_launcher() {
    SSContext::instance().clear();
    lv_obj_t* scr = lv_scr_act();
    lv_obj_clean(scr);

    // Title
    lv_obj_t* title = lv_label_create(scr);
    lv_label_set_text(title, "{{ device_friendly_name or 'ScreenSchema' }}");
    lv_obj_set_style_text_font(title, &lv_font_montserrat_18, 0);
    lv_obj_align(title, LV_ALIGN_TOP_MID, 0, 8);

    // Grid of app buttons
    static constexpr int COLS = {{ 3 if display_width >= 240 else 2 }};
    static constexpr int PAD = 8;
    int btn_w = (DISP_W - PAD * (COLS + 1)) / COLS;
    int btn_h = 64;
    int start_y = 40;

    for (int i = 0; i < NUM_APPS; i++) {
        int col = i % COLS;
        int row = i / COLS;
        int x = PAD + col * (btn_w + PAD);
        int y = start_y + row * (btn_h + PAD);

        lv_obj_t* btn = lv_btn_create(scr);
        lv_obj_set_size(btn, btn_w, btn_h);
        lv_obj_set_pos(btn, x, y);
        lv_obj_add_event_cb(btn, launcher_btn_cb, LV_EVENT_CLICKED,
                            (void*)(intptr_t)i);

        // Icon + label inside button
        if (app_table[i].icon) {
            lv_obj_t* img = lv_img_create(btn);
            lv_img_set_src(img, app_table[i].icon);
            lv_obj_align(img, LV_ALIGN_LEFT_MID, 4, 0);

            lv_obj_t* lbl = lv_label_create(btn);
            lv_label_set_text(lbl, app_table[i].name);
            lv_obj_align(lbl, LV_ALIGN_LEFT_MID, 56, 0);
        } else {
            lv_obj_t* lbl = lv_label_create(btn);
            lv_label_set_text(lbl, app_table[i].name);
            lv_obj_center(lbl);
        }
    }

    printf("Launcher — %d apps. Click to open, Backspace to return.\n", NUM_APPS);
}

static void show_app(int index) {
    if (index < 0 || index >= NUM_APPS) return;

    SSContext::instance().clear();
    lv_obj_t* scr = lv_scr_act();
    lv_obj_clean(scr);

    // Back button
    lv_obj_t* back = lv_btn_create(scr);
    lv_obj_set_size(back, 50, 28);
    lv_obj_align(back, LV_ALIGN_TOP_LEFT, 4, 4);
    lv_obj_add_event_cb(back, back_btn_cb, LV_EVENT_CLICKED, nullptr);
    lv_obj_t* back_lbl = lv_label_create(back);
    lv_label_set_text(back_lbl, LV_SYMBOL_LEFT);
    lv_obj_center(back_lbl);

    // App title
    lv_obj_t* title = lv_label_create(scr);
    lv_label_set_text(title, app_table[index].name);
    lv_obj_set_style_text_font(title, &lv_font_montserrat_16, 0);
    lv_obj_align(title, LV_ALIGN_TOP_MID, 0, 8);

    // App content container (below title bar)
    lv_obj_t* container = lv_obj_create(scr);
    lv_obj_remove_style_all(container);
    lv_obj_set_size(container, DISP_W, DISP_H - 36);
    lv_obj_set_pos(container, 0, 36);
    lv_obj_add_flag(container, LV_OBJ_FLAG_SCROLLABLE);
    lv_obj_set_scroll_dir(container, LV_DIR_VER);

    app_table[index].app->simBuildUI(container);

    printf("Opened app '%s'. Backspace or back button to return.\n", app_table[index].name);
}

// ---------------------------------------------------------------------------
// Event loop
// ---------------------------------------------------------------------------
static bool sdl_poll_events() {
    SDL_Event e;
    while (SDL_PollEvent(&e)) {
        switch (e.type) {
            case SDL_QUIT:
                return false;
            case SDL_MOUSEMOTION:
                mouse_x = e.motion.x;
                mouse_y = e.motion.y;
                break;
            case SDL_MOUSEBUTTONDOWN:
                mouse_pressed = true;
                break;
            case SDL_MOUSEBUTTONUP:
                mouse_pressed = false;
                break;
            case SDL_KEYDOWN:
                if (e.key.keysym.sym == SDLK_ESCAPE) return false;
                if (e.key.keysym.sym == SDLK_BACKSPACE) want_back = true;
                break;
        }
    }
    return true;
}

__attribute__((weak)) void register_custom_widgets() {}

int main(int argc, char* argv[]) {
    (void)argc; (void)argv;

    // SDL init
    if (SDL_Init(SDL_INIT_VIDEO) != 0) {
        fprintf(stderr, "SDL_Init failed: %s\n", SDL_GetError());
        return 1;
    }

    sdl_window = SDL_CreateWindow(
        "screenschema sim — {{ board_id }}",
        SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED,
        DISP_W, DISP_H, 0
    );
    sdl_renderer = SDL_CreateRenderer(sdl_window, -1, SDL_RENDERER_ACCELERATED);
    sdl_texture  = SDL_CreateTexture(sdl_renderer, SDL_PIXELFORMAT_RGB565,
                                     SDL_TEXTUREACCESS_STREAMING, DISP_W, DISP_H);

    // LVGL init
    lv_init();

    // Display driver
    static lv_disp_draw_buf_t draw_buf;
    static lv_color_t buf1[DISP_W * 40];
    lv_disp_draw_buf_init(&draw_buf, buf1, nullptr, DISP_W * 40);

    static lv_disp_drv_t disp_drv;
    lv_disp_drv_init(&disp_drv);
    disp_drv.hor_res  = DISP_W;
    disp_drv.ver_res  = DISP_H;
    disp_drv.draw_buf = &draw_buf;
    disp_drv.flush_cb = sdl_flush_cb;
    lv_disp_drv_register(&disp_drv);

    // Mouse input
    static lv_indev_drv_t indev_drv;
    lv_indev_drv_init(&indev_drv);
    indev_drv.type    = LV_INDEV_TYPE_POINTER;
    indev_drv.read_cb = sdl_mouse_read_cb;
    lv_indev_drv_register(&indev_drv);

    // Apply dark theme
    lv_theme_t* theme = lv_theme_default_init(
        lv_disp_get_default(), lv_palette_main(LV_PALETTE_BLUE),
        lv_palette_main(LV_PALETTE_CYAN), true, LV_FONT_DEFAULT);
    lv_disp_set_theme(lv_disp_get_default(), theme);

    // Widget factory
    SSWidgetFactory::instance();
    register_custom_widgets();

    printf("screenschema sim — {{ display_width }}×{{ display_height }} on {{ board_id }}\n");
    show_launcher();

    // Main loop
    while (sdl_poll_events()) {
        if (want_back) {
            want_back = false;
            show_launcher();
        }
        lv_tick_inc(10);
        lv_timer_handler();
        SDL_Delay(10);
    }

    SDL_DestroyTexture(sdl_texture);
    SDL_DestroyRenderer(sdl_renderer);
    SDL_DestroyWindow(sdl_window);
    SDL_Quit();
    return 0;
}
