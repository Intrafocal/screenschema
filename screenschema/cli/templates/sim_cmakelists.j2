# Generated by screenschema sim — do not edit manually
cmake_minimum_required(VERSION 3.16)
project(screenschema_sim C CXX)
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_C_STANDARD 11)

# SDL2
find_package(PkgConfig REQUIRED)
pkg_check_modules(SDL2 REQUIRED sdl2)

# Paths
set(SIM_DIR      "{{ sim_dir }}")
set(RUNTIME_DIR  "{{ runtime_dir }}")

# LVGL — fetch v8.3 from GitHub
include(FetchContent)
FetchContent_Declare(
    lvgl
    GIT_REPOSITORY https://github.com/lvgl/lvgl.git
    GIT_TAG        v8.3.11
)
# Point LVGL at our lv_conf.h before it builds
set(LV_CONF_PATH "${SIM_DIR}/lv_conf.h" CACHE STRING "" FORCE)
set(LV_CONF_INCLUDE_SIMPLE ON CACHE BOOL "" FORCE)
FetchContent_MakeAvailable(lvgl)

# Disable LVGL examples/demos — we only need the core library
set_target_properties(lvgl_examples PROPERTIES EXCLUDE_FROM_ALL TRUE)
set_target_properties(lvgl_demos PROPERTIES EXCLUDE_FROM_ALL TRUE)

# Make sure LVGL can find lv_conf.h
target_include_directories(lvgl PUBLIC "${SIM_DIR}")
target_compile_definitions(lvgl PUBLIC LV_CONF_INCLUDE_SIMPLE=1)

# Portable runtime sources
set(RUNTIME_SRCS
    "${RUNTIME_DIR}/core/ss_widget_factory.cpp"
    "${RUNTIME_DIR}/core/ss_context.cpp"
    "${RUNTIME_DIR}/core/ss_event_bus.cpp"
    "${RUNTIME_DIR}/core/ss_app_base.cpp"
)

# Generated app sources
set(APP_SRCS
{% for app in apps %}
    "${CMAKE_CURRENT_SOURCE_DIR}/main/{{ app.class_name }}.cpp"
{% endfor %}
{% for icon_src in icon_srcs %}
    "${CMAKE_CURRENT_SOURCE_DIR}/main/{{ icon_src }}"
{% endfor %}
)

add_executable(screenschema_sim
    "${CMAKE_CURRENT_SOURCE_DIR}/sim_main.cpp"
    "${CMAKE_CURRENT_SOURCE_DIR}/main/handlers.cpp"
    ${RUNTIME_SRCS}
    ${APP_SRCS}
)

target_include_directories(screenschema_sim PRIVATE
    # Compat shims FIRST — shadow real ESP headers
    "${SIM_DIR}/compat"
    # LVGL conf
    "${SIM_DIR}"
    # Runtime headers
    "${RUNTIME_DIR}/core"
    "${RUNTIME_DIR}/hal"
    # Generated code
    "${CMAKE_CURRENT_SOURCE_DIR}/main"
    # SDL2
    ${SDL2_INCLUDE_DIRS}
)

target_link_directories(screenschema_sim PRIVATE ${SDL2_LIBRARY_DIRS})
target_link_libraries(screenschema_sim PRIVATE lvgl ${SDL2_LIBRARIES})
