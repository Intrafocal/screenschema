cmake_minimum_required(VERSION 3.16)

# Locate the screenschema runtime component.
# Resolution order:
#   1. SCREENSCHEMA_DIR environment variable (CI / explicit override)
#   2. Path relative to this CMakeLists.txt, computed at codegen time
#      (works for typical submodule / fixed-layout checkouts)
if(DEFINED ENV{SCREENSCHEMA_DIR})
    set(_ss_dir "$ENV{SCREENSCHEMA_DIR}")
else()
    get_filename_component(_ss_dir
        "${CMAKE_CURRENT_LIST_DIR}/{{ relative_screenschema_dir }}" ABSOLUTE)
    if(NOT EXISTS "${_ss_dir}/runtime/CMakeLists.txt")
        message(FATAL_ERROR
            "ScreenSchema runtime not found at:\n  ${_ss_dir}\n"
            "Set the SCREENSCHEMA_DIR environment variable to the absolute "
            "path of the screenschema package, or re-run codegen from a "
            "directory where the relative path resolves correctly.")
    endif()
endif()

set(EXTRA_COMPONENT_DIRS "${_ss_dir}"
{% for d in extra_component_dirs %}
    "${CMAKE_CURRENT_LIST_DIR}/{{ d }}"
{% endfor %}
