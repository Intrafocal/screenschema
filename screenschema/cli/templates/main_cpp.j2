// Generated by screenschema — do not edit manually
// Board: {{ board_id }}

#include <stdio.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_log.h"
#include "nvs_flash.h"
#include "esp_brookesia.hpp"

{% if early_init_gpio_high or early_init_gpio_low %}
#include "driver/gpio.h"
{% endif %}
#include "ss_hal.hpp"
#include "ss_context.hpp"
#include "ss_widget_factory.hpp"
#include "ss_device.hpp"
#include "ss_wifi_manager.hpp"
#include "ss_update_manager.hpp"
#include "ss_http_client.hpp"
{% if gw_enabled %}
#include "ss_gateway.hpp"
{% endif %}
#include "ss_shell.hpp"
{% if system_app_enabled %}
#include "ss_system_app.hpp"
{% endif %}
{% if server_enabled %}
#include "ss_device_server.hpp"
#include "ss_notification.hpp"
{% endif %}
{% if server_mdns %}
#include "ss_mdns.hpp"
{% endif %}
{% if heartbeat_enabled %}
#include "ss_heartbeat.hpp"
{% endif %}
{% if ws_enabled %}
#include "ss_websocket.hpp"
{% endif %}
{% if has_audio %}
#include "ss_audio_queue.hpp"
{% endif %}
#include "ss_background.hpp"
{% if serial_bridge_enabled %}
#include "ss_serial_bridge.hpp"
{% endif %}
{% if wifi_driver == "hosted" %}
#include "ss_wifi_transport_hosted.hpp"
{% else %}
#include "ss_wifi_transport_native.hpp"
{% endif %}

// Display driver
{% if display_driver == "st7701s_dsi" %}
#include "st7701s_dsi.hpp"
{% elif display_driver == "ili9341" %}
#include "ili9341.hpp"
{% elif display_driver == "st7789" %}
#include "st7789.hpp"
{% elif display_driver == "gc9a01" %}
#include "gc9a01.hpp"
{% endif %}

// Touch driver
{% if touch_driver == "gt911" %}
#include "gt911.hpp"
{% elif touch_driver == "ft6236" %}
#include "ft6236.hpp"
{% elif touch_driver == "xpt2046" %}
#include "xpt2046.hpp"
{% elif touch_driver == "cst816" %}
#include "cst816.hpp"
{% endif %}

// Audio driver
{% if audio_driver == "es8311" %}
#include "ss_audio_es8311.hpp"
{% elif audio_driver == "i2s" %}
#include "ss_audio_i2s.hpp"
{% endif %}

// Input devices (D2/D3)
{% if has_keyboard %}
#include "ss_keyboard_i2c.hpp"
{% endif %}
{% if has_trackball %}
#include "ss_trackball_gpio.hpp"
{% endif %}
{% if has_keyboard or has_trackball %}
#include "ss_input.hpp"
{% endif %}
{% if has_battery %}
#include "ss_battery.hpp"
{% endif %}

// Generated app headers
{% for app in apps %}
#include "{{ app.class_name }}.hpp"
{% endfor %}

#include "handlers.hpp"

static const char* TAG = "SS_MAIN";

__attribute__((weak)) void register_custom_widgets() {}

extern "C" void app_main(void) {
    esp_err_t ret = nvs_flash_init();
    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND) {
        ESP_ERROR_CHECK(nvs_flash_erase());
        ESP_ERROR_CHECK(nvs_flash_init());
    }

{% if early_init_gpio_high or early_init_gpio_low %}
    // Board early init — power gates and CS deassert (D6)
{% for pin in early_init_gpio_high %}
    gpio_set_direction(GPIO_NUM_{{ pin }}, GPIO_MODE_OUTPUT);
    gpio_set_level(GPIO_NUM_{{ pin }}, 1);
{% endfor %}
{% for pin in early_init_gpio_low %}
    gpio_set_direction(GPIO_NUM_{{ pin }}, GPIO_MODE_OUTPUT);
    gpio_set_level(GPIO_NUM_{{ pin }}, 0);
{% endfor %}
    vTaskDelay(pdMS_TO_TICKS(50));  // Allow power rails to stabilize
{% endif %}

    // Device identity — baked at build time (R4.1)
    SSDevice::init("{{ device_id }}", "{{ device_location }}", "{{ device_friendly_name }}");

    // Display driver
{% if display_driver == "st7701s_dsi" %}
    SSDisplayST7701SDSIConfig disp_cfg = {
        .width          = {{ display_width }},
        .height         = {{ display_height }},
        .rotation       = 0,
        .backlight_gpio = {{ display_backlight_gpio }},
        .lane_num       = 2,
        .lane_mbps      = 500,
    };
    SSDisplayST7701SDSI display(disp_cfg);
{% elif display_driver == "ili9341" %}
    SSDisplayILI9341Config disp_cfg = {
        .spi_host       = {{ display_spi_host }},
        .pin_cs         = {{ display_pin_cs }},
        .pin_dc         = {{ display_pin_dc }},
        .pin_rst        = {{ display_pin_rst }},
        .pin_backlight  = {{ display_backlight_gpio }},
        .pin_sclk       = {{ display_pin_sclk }},
        .pin_mosi       = {{ display_pin_mosi }},
        .pin_miso       = {{ display_pin_miso }},
        .width          = {{ display_width }},
        .height         = {{ display_height }},
        .rotation       = {{ display_rotation }},
        .swap_xy        = {{ display_swap_xy }},
        .mirror_x       = {{ display_mirror_x }},
        .mirror_y       = {{ display_mirror_y }},
    };
    SSDisplayILI9341 display(disp_cfg);
{% elif display_driver == "st7789" %}
    SSDisplayST7789Config disp_cfg = {
        .spi_host       = {{ display_spi_host }},
        .pin_cs         = {{ display_pin_cs }},
        .pin_dc         = {{ display_pin_dc }},
        .pin_rst        = {{ display_pin_rst }},
        .pin_backlight  = {{ display_backlight_gpio }},
        .pin_sclk       = {{ display_pin_sclk }},
        .pin_mosi       = {{ display_pin_mosi }},
        .pin_miso       = -1,
        .width          = {{ display_width }},
        .height         = {{ display_height }},
        .rotation       = {{ display_rotation }},
        .swap_xy        = {{ display_swap_xy }},
        .mirror_x       = {{ display_mirror_x }},
        .mirror_y       = {{ display_mirror_y }},
    };
    SSDisplayST7789 display(disp_cfg);
{% endif %}

    // Touch driver
{% if touch_driver == "gt911" %}
    SSTouchGT911Config touch_cfg = {
        .sda_gpio = {{ touch_sda }},
        .scl_gpio = {{ touch_scl }},
        .rst_gpio = {{ touch_rst }},
        .int_gpio = {{ touch_int }},
        .width    = {{ display_width }},
        .height   = {{ display_height }},
        .swap_xy  = {{ touch_swap_xy }},
        .mirror_x = {{ touch_mirror_x }},
        .mirror_y = {{ touch_mirror_y }},
    };
    SSTouchGT911 touch(touch_cfg);
{% elif touch_driver == "ft6236" %}
    SSTouchFT6236Config touch_cfg = {
        .sda_gpio = {{ touch_sda }},
        .scl_gpio = {{ touch_scl }},
        .rst_gpio = {{ touch_rst }},
        .int_gpio = {{ touch_int }},
        .width    = {{ display_width }},
        .height   = {{ display_height }},
        .swap_xy  = {{ touch_swap_xy }},
        .mirror_x = {{ touch_mirror_x }},
        .mirror_y = {{ touch_mirror_y }},
    };
    SSTouchFT6236 touch(touch_cfg);
{% endif %}

    // Audio driver (R2.1)
{% if audio_driver == "es8311" %}
    SSAudioES8311Config audio_cfg = {
        .codec_i2c_addr  = {{ "0x%02X" | format(audio_codec_i2c_addr) }},
        .i2s_port        = static_cast<i2s_port_t>({{ audio_i2s_port }}),
        .sample_rate     = {{ audio_sample_rate }},
        .bits            = {{ audio_bits }},
        .pin_mck         = {{ audio_pin_mck }},
        .pin_bck         = {{ audio_pin_bck }},
        .pin_ws          = {{ audio_pin_ws }},
        .pin_dout        = {{ audio_pin_dout }},
        .pin_din         = {{ audio_pin_din }},
        .amp_enable_gpio = {{ audio_amp_gpio }},
        .amp_active_low  = {{ audio_amp_active_low }},
    };
    SSAudioES8311 audio(audio_cfg);
{% elif audio_driver == "i2s" %}
    SSAudioI2SConfig audio_cfg = {
        .mic = {
{% if audio_mic_driver == "i2s_std" %}
            .mode        = SSAudioMicConfig::Mode::I2S_STD,
{% elif audio_mic_driver == "i2s_pdm" %}
            .mode        = SSAudioMicConfig::Mode::I2S_PDM,
{% else %}
            .mode        = SSAudioMicConfig::Mode::NONE,
{% endif %}
            .sample_rate = {{ audio_mic_sample_rate }},
            .bits        = {{ audio_mic_bits }},
            .pin_clk     = {{ audio_mic_pin_clk }},
            .pin_data    = {{ audio_mic_pin_data }},
            .pin_ws      = {{ audio_mic_pin_ws }},
            .gain_db     = {{ audio_mic_gain_db }},
            .i2s_port    = static_cast<i2s_port_t>({{ audio_mic_i2s_port }}),
        },
        .spk = {
{% if audio_spk_driver == "i2s_std" %}
            .mode             = SSAudioSpeakerConfig::Mode::I2S_STD,
{% else %}
            .mode             = SSAudioSpeakerConfig::Mode::NONE,
{% endif %}
            .sample_rate      = {{ audio_spk_sample_rate }},
            .bits             = {{ audio_spk_bits }},
            .pin_bclk         = {{ audio_spk_pin_bclk }},
            .pin_lrclk        = {{ audio_spk_pin_lrclk }},
            .pin_data         = {{ audio_spk_pin_data }},
            .amp_enable_gpio  = {{ audio_spk_amp_gpio }},
            .i2s_port         = static_cast<i2s_port_t>({{ audio_spk_i2s_port }}),
        },
    };
    SSAudioI2S audio(audio_cfg);
{% endif %}

    // HAL init
    SSHalConfig hal_cfg = {
        .display     = &display,
{% if touch_driver %}
        .touch       = &touch,
{% else %}
        .touch       = nullptr,
{% endif %}
{% if has_audio %}
        .audio       = &audio,
{% else %}
        .audio       = nullptr,
{% endif %}
        .lvgl_buf_kb = {{ lvgl_buf_kb }},
    };
    ESP_ERROR_CHECK(ss_hal_init(hal_cfg));
{% if has_audio %}
    SSAudioQueue::instance().start();  // R2.4 — playback queue on core 1
{% endif %}

{% if has_keyboard or has_trackball %}
    // LVGL input group — required for keypad/encoder input devices to drive widget focus
    lv_group_t* input_group = lv_group_create();
    lv_group_set_default(input_group);
{% endif %}
{% if has_keyboard %}
    // I2C Keyboard (D2)
    SSKeyboardI2CConfig kbd_cfg = {
        .i2c_addr       = {{ "0x%02X" | format(keyboard_i2c_addr) }},
        .int_gpio       = {{ keyboard_int_gpio }},
        .backlight_ctrl = {{ "true" if keyboard_backlight else "false" }},
        .sda_gpio       = {{ touch_sda }},
        .scl_gpio       = {{ touch_scl }},
    };
    SSKeyboardI2C keyboard(kbd_cfg);
    if (keyboard.init() == ESP_OK) {
        lv_indev_set_group(keyboard.lv_indev(), input_group);
    } else {
        ESP_LOGE(TAG, "Keyboard init failed — keyboard input disabled");
    }
{% endif %}
{% if has_trackball %}
    // GPIO Trackball (D3)
    SSTrackballGPIOConfig tb_cfg = {
        .pin_up    = {{ trackball_pin_up }},
        .pin_down  = {{ trackball_pin_down }},
        .pin_left  = {{ trackball_pin_left }},
        .pin_right = {{ trackball_pin_right }},
        .pin_click = {{ trackball_pin_click }},
    };
    SSTrackballGPIO trackball(tb_cfg);
    if (trackball.init() == ESP_OK) {
        lv_indev_set_group(trackball.lv_indev(), input_group);
    } else {
        ESP_LOGE(TAG, "Trackball init failed — trackball input disabled");
    }
{% endif %}

{% if has_battery %}
    // Battery monitoring (D9)
    {
        SSBatteryConfig batt_cfg = {
            .adc_gpio           = {{ battery_adc_gpio }},
            .voltage_divider    = {{ battery_voltage_divider }}f,
            .full_mv            = {{ battery_full_mv }},
            .empty_mv           = {{ battery_empty_mv }},
            .sample_interval_ms = {{ battery_sample_ms }},
        };
        SSBattery::instance().init(batt_cfg);
    }
{% endif %}

    SSWidgetFactory::instance();  // triggers built-in type registration
    register_custom_widgets();

    // WiFi transport init and status bar sync
{% if wifi_driver == "hosted" %}
    SSWifiTransportHostedConfig wifi_transport_cfg = {
        .spi_host      = {{ wifi_hosted_spi_host }},
        .pin_mosi      = {{ wifi_hosted_pin_mosi }},
        .pin_miso      = {{ wifi_hosted_pin_miso }},
        .pin_sclk      = {{ wifi_hosted_pin_sclk }},
        .pin_cs        = {{ wifi_hosted_pin_cs }},
        .pin_handshake = {{ wifi_hosted_pin_handshake }},
        .pin_reset     = {{ wifi_hosted_pin_reset }},
    };
    SSWifiManager::instance().init(std::make_unique<SSWifiTransportHosted>(wifi_transport_cfg));
{% else %}
    SSWifiManager::instance().init(std::make_unique<SSWifiTransportNative>());
{% endif %}
    SSWifiManager::instance().autoConnect();  // reconnect from NVS if credentials saved (R1.3)

{% if gw_enabled %}
    // IoT Gateway registration — must complete before using any network services.
    // Device registers with PSK, receives JWT + runtime config (ws/ota/heartbeat URLs).
    SSGateway::instance().init("{{ gw_url }}", "{{ device_id }}", "{{ gw_secret }}");
    if (SSGateway::instance().registerDevice() == ESP_OK) {
        SSHttpClient::instance().setAuthToken(SSGateway::instance().token());
        // Register "gateway" endpoint so handler code can use SSHttpClient::instance().get("gateway", ...)
        SSEndpointConfig gw_ep;
        gw_ep.base_url   = SSGateway::instance().gatewayUrl() + "/api/gateway";
        gw_ep.timeout_ms = 5000;
        gw_ep.retry      = 2;
        SSHttpClient::instance().registerEndpoint("gateway", std::move(gw_ep));
    } else {
        ESP_LOGE(TAG, "Gateway registration failed — network services may not work");
    }
{% endif %}

{% if network_endpoints %}
    // Named HTTP endpoint registry (R1.1)
{% for ep in network_endpoints %}
    {
        SSEndpointConfig ep_cfg;
        ep_cfg.base_url   = "{{ ep.base_url }}";
        ep_cfg.timeout_ms = {{ ep.timeout_ms }};
        ep_cfg.retry      = {{ ep.retry }};
        SSHttpClient::instance().registerEndpoint("{{ ep.name }}", std::move(ep_cfg));
    }
{% endfor %}
{% endif %}

    // Brookesia phone shell
    ESP_Brookesia_Phone phone;
    ESP_Brookesia_PhoneStylesheet_t stylesheet = {{ brookesia_stylesheet }}();
{% if brookesia_gesture_nav_back %}
    stylesheet.manager.flags.enable_gesture_navigation_back = 1;
{% endif %}
    phone.addStylesheet(stylesheet);
    phone.activateStylesheet(stylesheet);

    if (!phone.begin()) {
        ESP_LOGE(TAG, "phone.begin() failed");
        return;
    }

{% if has_keyboard or has_trackball %}
    // brookesia's phone.begin() may have replaced the default group with one
    // of its own internal groups.  Re-set our input group as the default so
    // widgets created by user apps (after this point) auto-add to it and
    // become reachable from the keyboard / trackball.
    //
    // KNOWN LIMITATION (B12): brookesia's launcher icons and built-in screens
    // are added to brookesia's internal groups, NOT this default group, so
    // the trackball can't navigate the launcher itself.  Handler code that
    // wants the keyboard / trackball to drive a custom widget tree should
    // explicitly call lv_indev_set_group() with the relevant group.
    lv_group_set_default(input_group);
{% endif %}

    SSShell::instance().init(&phone);

    // Keep the brookesia status bar WiFi icon in sync with connection state.
    SSWifiManager::instance().onStateChanged([&phone](bool connected, int8_t rssi) {
        auto* sb = phone.getHome().getStatusBar();
        if (!sb) return;
        using WS = ESP_Brookesia_StatusBar::WifiState;
        if (!connected) {
            sb->setWifiIconState(WS::DISCONNECTED);
        } else if (rssi >= -67) {
            sb->setWifiIconState(WS::SIGNAL_3);
        } else if (rssi >= -80) {
            sb->setWifiIconState(WS::SIGNAL_2);
        } else {
            sb->setWifiIconState(WS::SIGNAL_1);
        }
    });

{% for app in apps %}
    static {{ app.class_name }} app_{{ loop.index }};
    phone.installApp(&app_{{ loop.index }});
    SSShell::instance().registerApp("{{ app.id }}", &app_{{ loop.index }});
{% endfor %}
{% if system_app_enabled %}
    static SSSystemApp system_app({{ "true" if system_app_wifi else "false" }}, {{ "true" if system_app_ota else "false" }}, "{{ ota_manifest_url }}");
    phone.installApp(&system_app);
{% endif %}

{% if server_enabled %}
    // Embedded HTTP device API server (R3.1 / R6.1 / R3.3 / R3.4)
    SSDeviceServer::instance().start({{ server_port }});
    SSNotification::instance().init();
{% endif %}
{% if server_mdns %}
    SSMdns::advertise({{ server_port }});  // R4.2 — <device_id>._screenschema._tcp.local
{% endif %}
{% if heartbeat_enabled %}
    SSHeartbeat::instance().start("{{ heartbeat_endpoint }}", "{{ heartbeat_path }}", {{ heartbeat_interval_s * 1000 }}U);  // R4.3
{% endif %}
{% if ws_enabled %}
{% if gw_enabled %}
    // Use gateway-provided WebSocket URL if available, fall back to static config
    {
        const auto& gw_ws = SSGateway::instance().wsUrl();
        if (!gw_ws.empty()) {
            SSWebSocket::instance().init(gw_ws, {{ ws_reconnect_ms }}U);
        } else {
            SSWebSocket::instance().init("{{ ws_url }}", {{ ws_reconnect_ms }}U);
        }
    }
{% else %}
    SSWebSocket::instance().init("{{ ws_url }}", {{ ws_reconnect_ms }}U);  // R1.2
{% endif %}
{% endif %}
{% if serial_bridge_enabled %}
    SSSerialBridge::instance().start({{ serial_bridge_uart }}, {{ serial_bridge_baud }});  // Phase 3
{% endif %}

    SSBackground::instance().startBootTasks();

    ESP_LOGI(TAG, "ScreenSchema started — {{ apps | length }} app(s) on {{ board_id }}");

    // LVGL tick + event loop
    while (1) {
        lv_tick_inc(10);
        lv_timer_handler();
        vTaskDelay(pdMS_TO_TICKS(10));
    }
}
